<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SensusSoft Career Application<  <style>
    body{font-family:Arial,sans-serif;max-width:700px;margin:40px auto;padding:20px;background:#f5f7fb}
    form{background:#fff;padding:25px;border-radius:12px;box-shadow:0 2px 10px rgba(0,0,0,.08)}
    h2{text-align:center}
    label{display:block;margin-top:15px;font-weight:bold}
    input,select,textarea,button{width:100%;padding:10px;margin-top:6px;border:1px solid #ccc;border-radius:8px;box-sizing:border-box}
    button{background:#2563eb;color:#fff;border:none;cursor:pointer;font-size:16px}
    button:hover{background:#1d4ed8}
    .note{margin-top:15px;font-size:13px;color:#666}
    .result{margin-top:15px;padding:12px;border-radius:8px;display:none}
    .success{background:#dcfce7;color:#166534}
    .error{background:#fee2e2;color:#991b1b}
  </style>
</head>
<body>

<form id="careerForm">
  <h2>SensusSoft Career Application Form</h2>

  <label for="fullName">Full Name *</label>
  <input id="fullName" type="text" required />

  <label for="email">Email *</label>
  <input id="email" type="email" required />

  <label for="appliedRole">Applied Role *</label>
<input id="appliedRole" type="text" placeholder="Enter Applied IT Role" required />

  <label for="yearsExperience">Years of Experience *</label>
  <input id="yearsExperience" type="number" min="0" step="0.1" required />

  <label for="skills">Known Skills (comma separated) *</label>
  <input id="skills" type="text" placeholder="React, Next.js, Firebase" required />

  <label for="resumeFile">Upload Resume PDF *</label>
  <input id="resumeFile" type="file" accept=".pdf" required />

  <button type="submit">Submit Application</button>
  <div class="note">Powered by SensusSoft AI Hiring Automation</div>
  <div id="result" class="result"></div>
</form>

<script>
const form = document.getElementById('careerForm');
const resultBox = document.getElementById('result');

function showResult(msg, ok){
  resultBox.style.display='block';
  resultBox.className='result ' + (ok ? 'success' : 'error');
  resultBox.innerText = msg;
}

form.addEventListener('submit', async (e)=>{
  e.preventDefault();

  const resume = document.getElementById('resumeFile').files[0];
  if(!resume){
    showResult('Please upload resume PDF.', false);
    return;
  }

  const fd = new FormData();
  const roleLower = String(body.appliedRole).toLowerCase().trim();
const roleMatched = ALLOWED_IT_ROLES.some(role => roleLower.includes(role));

if (!roleMatched) {
  return res.status(400).json({
    error: 'Currently SensusSoft is accepting applications only for IT, Software Development, and Technical Engineering related positions.'
  });
}
  fd.append('fullName', document.getElementById('fullName').value.trim());
  fd.append('email', document.getElementById('email').value.trim());
  fd.append('appliedRole', document.getElementById('appliedRole').value.trim());
  fd.append('yearsExperience', document.getElementById('yearsExperience').value);
  fd.append('skills', document.getElementById('skills').value.trim());
  fd.append('resumeFile', resume);

  try{
    const resp = await fetch('http://localhost:4000/api/career-apply', {
      method:'POST',
      body: fd
    });

    const json = await resp.json();

    if(resp.ok){
      showResult('Application submitted successfully. Please check your email for the technical assignment.', true);
      form.reset();
    }else{
      showResult(json.error || 'Submission failed.', false);
    }
  }catch(err){
    showResult('Network error: ' + err.message, false);
  }
});
</script>

</body>
</html>
