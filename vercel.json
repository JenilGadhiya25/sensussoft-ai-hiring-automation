{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "demo-form/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/demo-form/(.*)",
      "dest": "/demo-form/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/",
      "dest": "/demo-form/demo-form.html"
    }
  ]
}